# ========================================
# ОКРУЖЕНИЕ И ПОРТЫF
# ========================================
NODE_ENV=production
PORT=3000

# ========================================
# BASE DE DONNÉES PostgreSQL
# ========================================
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://avtokond_user:avtokond_password@avtokond_db:5432/avtokond_prod

# ========================================
# АУТЕНТИФИКАЦИЯ JWT
# ========================================
# Используйте сильный, случайный ключ (минимум 32 символа)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production-12345678

# ========================================
# EMAIL КОНФИГУРАЦИЯ (Yandex Mail)
# ========================================
SMTP_HOST=smtp.yandex.com
SMTP_PORT=587
SMTP_USER=your-email@yandex.com
SMTP_PASS=your-app-password-from-yandex
ADMIN_EMAIL=admin@avtokond-ugra.ru
ADMIN_PHONE=+7-999-999-99-99

# ========================================
# ВНЕШНИЕ НАСТРОЙКИ
# ========================================
# URL где хостится приложение (для писем)
APP_URL=https://avtokond-ugra.ru
APP_NAME=Avtokond UGra

# ========================================
# ЛОГИРОВАНИЕ И ОТЛАДКА
# ========================================
DEBUG=false
LOG_LEVEL=info
